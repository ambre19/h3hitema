pipeline {
    agent any

    stages {
        stage('Checkout-SCM') {
            steps {
                cleanWs()
                git branch: 'main', credentialsId: 'user-ambre19', url: 'https://github.com/srcmed/b3depogithub.git'
            }
        }

        stage('Build-image') {
            steps {
                sh 'docker build -t mon-apache2 .'
            }
        }

        stage('Create-conteneur') {
            steps {
                sh '''
                    docker stop contapache01 2>/dev/null || true
                    docker rm contapache01 2>/dev/null || true
                '''
                sh 'docker run -d --name contapache01 --hostname contapache01 -v ./volumecontapache01:/var/www/html --network macvlan192 --ip 192.168.1.20 mon-apache2'
                sh 'docker ps && docker exec contapache01 ifconfig'
                sh 'docker exec contapache01 service ssh start'
                sh 'docker exec contapache01 /etc/init.d/apache2 start'
                sh 'docker exec contapache01 /etc/init.d/apache2 status'
            }
        }

        stage('Copy-fichiers-mysite-dans-contapache01') {
            steps {
                sh 'cp -rf ./mysite ./volumecontapache01'
            }
        }
    }
}
